# MiniRaft Configuration

# Gateway
PORT=8080
REPLICA_URLS=http://localhost:5001,http://localhost:5002,http://localhost:5003

# Timeouts (milliseconds)
TIMEOUT_REPLICA_STATUS=500
TIMEOUT_STROKE_FORWARD=10000
TIMEOUT_CLEAR_FORWARD=10000
TIMEOUT_COMMIT_POLLING=5000
LEADER_CACHE_TTL=1000

# Rate Limiting - Performance focused (high throughput)
MAX_REQUESTS_PER_SECOND=1000
MAX_VIOLATIONS=100
VIOLATION_RESET_TIME=60000

# Replica Settings - FASTER ELECTION FOR DEMO
REPLICA_ID=1
ELECTION_TIMEOUT_MIN=800
ELECTION_TIMEOUT_MAX=1200
HEARTBEAT_INTERVAL=300
